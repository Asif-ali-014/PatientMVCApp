@model List<PatientMVCApp.Models.Patient>

<h2>Patient List</h2>

<form method="get">
    <input type="text" name="search" placeholder="Search patient" />
    <button type="submit">Search</button>
</form>

<br />

<a href="/Patient/Create">Add Patient</a>

<br />
<br />

<table border="1">

    <tr>
        <th>Name</th>
        <th>Age</th>
        <th>Gender</th>
        <th>Email</th>
        <th>Actions</th>
    </tr>

    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Name</td>
            <td>@p.Age</td>
            <td>@p.Gender</td>
            <td>@p.Email</td>

            <td>
                <a href="/Patient/Edit/@p.Id">Edit</a>
                <a href="/Patient/Delete/@p.Id">Delete</a>
            </td>

        </tr>
    }

</table>
<br />
<a href="/Logs">View Logs</a>
<br /><br />